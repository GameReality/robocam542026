<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Settings"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- HTTP Port -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HTTP Port"
            android:layout_marginTop="8dp"/>
        <EditText
            android:id="@+id/etPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="8088"
            android:inputType="number"
            android:text="8088"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Driver Credentials -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Login"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/etDriverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="admin"
            android:text="admin"
            android:layout_marginTop="8dp"/>
        <EditText
            android:id="@+id/etDriverPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123"
            android:text="123"
            android:inputType="textPassword"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Spectator Access -->
        <CheckBox
            android:id="@+id/cbAllowSpectators"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allow Spectators"
            android:checked="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spectator Login"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>
        <EditText
            android:id="@+id/etSpectatorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="guest"
            android:text="guest"
            android:layout_marginTop="8dp"/>
        <EditText
            android:id="@+id/etSpectatorPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="123"
            android:text="123"
            android:inputType="textPassword"
            android:layout_marginTop="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <!-- Camera Quality -->
        <TextView
            android:id="@+id/tvQualityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Camera JPEG Quality: 50%"
            android:textStyle="bold"/>
        <SeekBar
            android:id="@+id/sbCameraQuality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnSaveServerSettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE SETTINGS"
            android:layout_marginTop="32dp"/>

    </LinearLayout>
</ScrollView>